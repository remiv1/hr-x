            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" FONT="Montserrat Regular" FONTSIZE="10" FCOLOR="AIO-Primary"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="10" FCOLOR="AIO-Primary" CH="Un standard moderne doit être :"/>
                <para PARENT="Default Paragraph Style"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" CH="structuré (types, schémas, contraintes)"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="1" BulletStr="•" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" CH="interopérable (tous outils, toutes entreprises)"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="1" BulletStr="•" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" CH="profond (données complètes, non aplaties)"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="1" BulletStr="•" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" CH="versionné (évolution maîtrisée)"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="1" BulletStr="•" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" CH="sécurisé (signature, intégrité)"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="1" BulletStr="•" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" CH="ouvert (non propriétaire)"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="1" BulletStr="•" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="10" FCOLOR="AIO-Primary" CH="Et il doit s'accompagner d'un écosystème complet :"/>
