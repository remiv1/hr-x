                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="un fichier léger (quelques ko) et une structure universelle et versionnable,"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" Bullet="1" BulletStr="•" Numeration="0"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="un visualiseur universel (HR-X reader),"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" Bullet="1" BulletStr="•" Numeration="0"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="une API ouverte pour une logique moderne,"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" Bullet="1" BulletStr="•" Numeration="0"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="une réduction massive de l'empreinte numérique."/>
