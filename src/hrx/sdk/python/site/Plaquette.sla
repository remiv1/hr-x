            <StoryText>
                <DefaultStyle FCOLOR="AIO-Primary"/>
                <ITEXT FONT="Fraunces Black" FONTSIZE="18" FCOLOR="AIO-Primary" CH="L'absurdité actuelle"/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="122.677165354331" YPOS="152.11470208015" OwnPage="0" ItemID="224355984" PTYPE="4" WIDTH="375.590551181102" HEIGHT="136.477611940298" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L375.591 0 L375.591 136.478 L0 136.478 L0 0 Z" copath="M0 0 L375.591 0 L375.591 136.478 L0 136.478 L0 0 Z" gXpos="0" gYpos="29.0149253731343" gWidth="375.590551181102" gHeight="198.6775179222" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" FONT="Montserrat Regular" FONTSIZE="10" FCOLOR="AIO-Primary"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="10" FCOLOR="AIO-Primary" CH="Aujourd’hui, un candidat :"/>
                <para PARENT="Default Paragraph Style"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="possède des données riches, structurées, précises,"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="1" BulletStr="•" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="puis les écrase dans un CV d’une page, un artefact figé, non structuré, non typé,"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="1" BulletStr="•" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="qu’il envoie par mail sous forme de PDF lourds, dupliqués à l’infini."/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" DROPLIN="2" Bullet="1" BulletStr="•" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="10" FCOLOR="AIO-Primary" CH="Ensuite, les entreprises :"/>
                <para PARENT="Default Paragraph Style"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="utilisent des parseurs pour re-gonfler ces données aplaties,"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" Bullet="1" BulletStr="•" Numeration="0"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="corrigent les erreurs à la main,"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" Bullet="1" BulletStr="•" Numeration="0"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="re-saisissent dans leurs outils,"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" Bullet="1" BulletStr="•" Numeration="0"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="perdent du temps, de l’information, et de l’argent."/>
                <trail PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" Bullet="1" BulletStr="•" Numeration="0"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="122.677165354331" YPOS="282.622047244095" OwnPage="0" ItemID="222950944" PTYPE="4" WIDTH="375.590551181102" HEIGHT="39.1552473851216" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L375.591 0 L375.591 39.1552 L0 39.1552 L0 0 Z" copath="M0 0 L375.591 0 L375.591 39.1552 L0 39.1552 L0 0 Z" gXpos="0" gYpos="159.522270537078" gWidth="375.590551181102" gHeight="198.6775179222" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle FCOLOR="AIO-Secondary"/>
                <ITEXT FONT="Caveat Regular" FONTSIZE="15" FCOLOR="AIO-Secondary" CH="On écrase des données riches pour ensuite payer des outils qui tentent de les reconstituer. C’est une absurdité systémique."/>
                <trail PARENT="Default Paragraph Style" ALIGN="1"/>
            </StoryText>
        </PAGEOBJECT>
