                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="SDK officiels (Python, JS/TS, Java, PHP),"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" Bullet="1" BulletStr="•" Numeration="0"/>
                <ITEXT FONTSIZE="12" FCOLOR="AIO-Primary" Unicode="25"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="Parseurs fiables (pas d'heuristiques bricolés),"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" Bullet="1" BulletStr="•" Numeration="0"/>
                <ITEXT FONTSIZE="12" FCOLOR="AIO-Primary" Unicode="25"/>
                <ITEXT FONT="Montserrat Regular" FONTSIZE="9" FCOLOR="AIO-Primary" KERN="-3" CH="API centrale (lecture, écriture, partage),"/>
                <para PARENT="Default Paragraph Style" LINESP="14" ParagraphEffectOffset="8.50393700787402" ParagraphEffectIndent="0" DROP="0" Bullet="1" BulletStr="•" Numeration="0"/>
