{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schema.audit-io.fr/hrx/1.0",
  "title": "HR-X v1.0",
  "description": "Portable candidate data — HR-X standard by Audit IO",
  "type": "object",
  "required": ["$hrx", "identity"],
  "additionalProperties": false,
  "definitions": {
    "skill_domains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["domain", "items"],
        "additionalProperties": false,
        "properties": {
          "domain": { "type": "string" },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label"],
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string" },
                "level": {
                  "type": "string",
                  "enum": ["beginner", "intermediate", "advanced", "expert"]
                }
              }
            }
          }
        }
      }
    }
  },
  "properties": {

    "$hrx": {
      "type": "object",
      "required": ["version", "schema", "date"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
        "schema":  { "type": "string", "format": "uri" },
        "issuer":  { "type": "string" },
        "date":    { "type": "string", "format": "date" },
        "lang":    { "type": "string", "pattern": "^[a-z]{2}$" }
      }
    },

    "identity": {
      "type": "object",
      "required": ["last_name", "first_name"],
      "additionalProperties": false,
      "properties": {
        "civility": {
          "type": "string",
          "enum": ["Mr.", "Mrs.", "Dr.", "Prof.", "Mx.", "Me", "other"]
        },
        "last_name":  { "type": "string" },
        "first_name": { "type": "string" },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "value"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["email", "phone", "linkedin", "github", "x",
                         "facebook", "instagram", "website", "other"]
              },
              "value":   { "type": "string" },
              "primary": { "type": "boolean" }
            }
          }
        },
        "location": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "city":        { "type": "string" },
            "postal_code": { "type": "string" },
            "country":     { "type": "string", "pattern": "^[A-Z]{2}$" },
            "mobility":    {
              "type": "string",
              "enum": ["local", "regional", "national", "international"]
            }
          }
        }
      }
    },

    "skills": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hard": { "$ref": "#/definitions/skill_domains" },
        "soft": { "$ref": "#/definitions/skill_domains" }
      }
    },

    "experiences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["position", "organisation", "period"],
        "additionalProperties": false,
        "properties": {
          "position":     { "type": "string" },
          "organisation": { "type": "string" },
          "sector":       { "type": "string" },
          "period": {
            "type": "object",
            "required": ["start"],
            "additionalProperties": false,
            "properties": {
              "start": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
              "end":   { "type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}$" }
            }
          },
          "description":  { "type": "string" },
          "achievements": { "type": "array", "items": { "type": "string" } },
          "projects": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["title"],
              "additionalProperties": false,
              "properties": {
                "title":       { "type": "string" },
                "description": { "type": "string" },
                "role":        { "type": "string" },
                "period": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "start": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
                    "end":   { "type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}$" }
                  }
                },
                "url": { "type": "string", "format": "uri" }
              }
            }
          }
        }
      }
    },

    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "institution", "year"],
        "additionalProperties": false,
        "properties": {
          "title":         { "type": "string" },
          "institution":   { "type": "string" },
          "year":          { "type": "integer", "minimum": 1900, "maximum": 2100 },
          "certification": { "type": "boolean" }
        }
      }
    },

    "credentials": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "awards": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title"],
            "additionalProperties": false,
            "properties": {
              "title":       { "type": "string" },
              "issuer":      { "type": "string" },
              "year":        { "type": "integer" },
              "description": { "type": "string" }
            }
          }
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name":         { "type": "string" },
              "position":     { "type": "string" },
              "organisation": { "type": "string" },
              "contact":      { "type": "string" }
            }
          }
        },
        "bibliography": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title"],
            "additionalProperties": false,
            "properties": {
              "title":   { "type": "string" },
              "authors": { "type": "array", "items": { "type": "string" } },
              "year":    { "type": "integer" },
              "type":    {
                "type": "string",
                "enum": ["article", "book", "conference", "report", "other"]
              },
              "url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    },

    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "availability": { "type": "string", "format": "date" },
        "contracts": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["permanent", "fixed-term", "freelance", "mission", "internship", "apprenticeship"]
          }
        },
        "remote":     { "type": "string", "enum": ["no", "partial", "full"] },
        "salary_min": { "type": ["integer", "null"] }
      }
    }

  }
}
